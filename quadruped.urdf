<?xml version="1.0"?>
<robot name="quadruped">

  <link name="base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://body.stl"/>
      </geometry>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://body.stl"/>
      </geometry>
    </collision>
  </link>

  <link name="FL_leg">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://Left_leg_front.stl"/>
      </geometry>
    </visual>
  </link>

  <joint name="FL_joint" type="revolute">
    <parent link="base_link"/>
    <child link="FL_leg"/>
    <origin xyz="0.15 0.1 0" rpy="0 0 0"/> <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="FR_leg">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://Right_leg_front.stl"/>
      </geometry>
    </visual>
  </link>

  <joint name="FR_joint" type="revolute">
    <parent link="base_link"/>
    <child link="FR_leg"/>
    <origin xyz="0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="BL_leg">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://Left_leg_back.stl"/>
      </geometry>
    </visual>
  </link>

  <joint name="BL_joint" type="revolute">
    <parent link="base_link"/>
    <child link="BL_leg"/>
    <origin xyz="-0.15 0.1 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

  <link name="BR_leg">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://Right_leg_back.stl"/>
      </geometry>
    </visual>
  </link>

  <joint name="BR_joint" type="revolute">
    <parent link="base_link"/>
    <child link="BR_leg"/>
    <origin xyz="-0.15 -0.1 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="10" velocity="1.0"/>
  </joint>

</robot>